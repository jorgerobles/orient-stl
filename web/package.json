{
  "name": "orient-stl-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:wasm": "wasm-pack build ../core --target bundler --out-dir ../web/pkg",
    "rebuild": "npm run build:wasm && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "typescript": "^5.7.0",
    "vite": "^8.1.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
